{
  "name": "gdsii-view",
  "displayName": "GDSII View",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.125.0"
  },
  "main": "./extension.cjs",
  "contributes": {
    "customEditors": [
      {
        "viewType": "gdsii-view.editor",
        "displayName": "GDSII Viewer",
        "selector": [
          {
            "filenamePattern": "*.gds"
          }
        ],
        "priority": "default"
      }
    ]
  }
}
